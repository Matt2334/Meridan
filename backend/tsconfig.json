{
  "compilerOptions": {
    "types": ["node", "express"],
    // "typeRoots": ["./node_modules/@types", "./src/types"],
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": false,
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*","./@types/**/*.ts", "prisma/library/redis.ts" ],
  "exclude": ["node_modules", "dist", "prisma"]
}